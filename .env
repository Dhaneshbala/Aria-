# ARIA — Environment Configuration
# Tuned for MacBook Air M4 16GB

# ── Ollama (local AI) ────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Best models for M4 MacBook Air 16GB:
# ── Ollama (local AI) ────────────────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434

# Formatted to distribute tasks across your specific downloaded models
REASONING_MODEL=qwen3:8b        # 5.2 GB — Handles complex text reasoning and essays
VISION_MODEL=qwen2.5vl:3b       # 2.2 GB — Handles your worksheet images and PDFs
FALLBACK_MODEL=llama3.2:3b      # 2.0 GB — Fast, lightweight backup model


# ── Student ──────────────────────────────────────────────────────────────────
STUDENT_NAME=Student
STUDENT_AGE=13

# ── Image Generation ─────────────────────────────────────────────────────────
# Pollinations.ai is used by default — free, no install, no GPU needed.
# Set SD_ENABLED=true only if you have Stable Diffusion A1111 installed.
IMAGE_GEN_BACKEND=pollinations
SD_ENABLED=false
SD_URL=http://127.0.0.1:7860
